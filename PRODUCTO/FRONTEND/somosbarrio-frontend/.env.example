# Desarrollo: ruta relativa; Vite reenvía /api al backend (ver VITE_BACKEND_PROXY_TARGET).
# Docker Compose: http://localhost:8080 | Spring local (mvn): http://localhost:8380
VITE_BACKEND_PROXY_TARGET=http://localhost:8080
# Producción: URL completa, p. ej. https://api.tudominio.cl/api/v1
VITE_API_URL=/api/v1
VITE_APP_NAME=Somos Barrio
VITE_ENV=development
# Plantillas para módulos trabajador (códigos en document_templates)
VITE_TEMPLATE_REPORTE_CODE=INFORME_TIPO
VITE_TEMPLATE_BITACORA_CODE=INFORME_TIPO