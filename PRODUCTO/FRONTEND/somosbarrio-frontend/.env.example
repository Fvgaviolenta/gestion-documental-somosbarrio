# Desarrollo: Vite sirve el SPA en :5173 y reenvía /api al backend.
# Docker Compose (recomendado): backend en http://localhost:8081
# Spring solo con Maven:         http://localhost:8380
VITE_BACKEND_PROXY_TARGET=http://localhost:8081

# Ruta relativa; el proxy antepone el host anterior
VITE_API_URL=/api/v1

VITE_APP_NAME=Somos Barrio
VITE_ENV=development

# Plantillas para módulos trabajador (códigos en document_templates, seeds V16)
VITE_TEMPLATE_REPORTE_CODE=INFORME_TIPO
VITE_TEMPLATE_BITACORA_CODE=INFORME_TIPO
