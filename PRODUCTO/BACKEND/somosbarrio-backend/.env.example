# =============================================================================
# Variables para Docker Compose (archivo en la RAÍZ de somosbarrio-backend)
# Copiar:  Copy-Item .env.example .env
# Uso:     docker compose up -d --build
# =============================================================================
#
# Compose crea PostgreSQL con:
#   - Base de datos:  somosbarrio
#   - Usuario:        somosbarrio_app
#   - Contraseña:     valor de DB_PASSWORD (abajo)
#
# El contenedor backend NO lee DB_HOST/DB_NAME de este archivo; usa la red
# interna Docker (host "db", BD "somosbarrio"). Solo se interpolan aquí las
# variables referenciadas en docker-compose.yml.

DB_PASSWORD=password

# Mínimo 32 caracteres UTF-8 (JwtService). No usar "cambia-esto" en producción.
JWT_SECRET=dev-only-cambia-en-produccion-openssl-rand-base64-64

# Opcional — envío de correo (sin credenciales, POST /documents/{id}/send fallará)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_NAME=Programa Somos Barrio
