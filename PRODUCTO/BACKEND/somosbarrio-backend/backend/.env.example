# =============================================================================
# Spring Boot LOCAL (./mvnw spring-boot:run) — carpeta backend/
# Copiar:  Copy-Item .env.example .env
# =============================================================================
#
# Escenario A — API en Docker, conectar desde Maven al Postgres del contenedor:
#   DB_HOST=localhost
#   DB_NAME=somosbarrio
#   DB_USER=somosbarrio_app
#   DB_PASSWORD=password          (igual que DB_PASSWORD en ../.env de Compose)
#
# Escenario B — Postgres instalado en Windows (sin Docker):
#   Crear BD y usuario manualmente, o ajustar nombres a tu instalación.

SPRING_PROFILES_ACTIVE=dev
DB_HOST=localhost
DB_PORT=5432
DB_NAME=somosbarrio
DB_USER=somosbarrio_app
DB_PASSWORD=password

JWT_SECRET=dev-only-cambia-en-produccion-openssl-rand-base64-64
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=7

APP_CORS_ORIGINS=http://localhost:5173

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_NAME=Programa Somos Barrio

UPLOAD_ROOT=./uploads
UPLOAD_MAX_MB=20
TEMPLATE_ROOT=./templates

# Windows — LibreOffice para PDF fiel al Word (opcional en local)
# LIBREOFFICE_PATH=C:/Program Files/LibreOffice/program/soffice.exe

LOG_LEVEL_ROOT=INFO
